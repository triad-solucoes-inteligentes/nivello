# Copy this file to `.env` (same folder) and fill in the values.
# `.env` is gitignored and is read at runtime by docker compose — secrets are
# never baked into the image.

# --- App runtime secrets (injected into the container) ---
MONGODB_URI=
AUTH_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=
# Must match your public HTTPS URL exactly (used by NextAuth for callbacks).
AUTH_URL=https://your-domain.com

# --- Reverse proxy / TLS (Caddy) ---
# Domain that points (A record) to this VM's public IP. For a quick test
# without buying a domain, you can use sslip.io, e.g. 203-0-113-25.sslip.io
DOMAIN=your-domain.com
# Email used for the Let's Encrypt account (expiry notices).
ACME_EMAIL=you@example.com
